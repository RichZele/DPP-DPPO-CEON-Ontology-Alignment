@prefix dpp:           <http://www.w3id.org/dpp#> .
@prefix notor65:       <http://www.w3id.org/dpp/fagerhult/notor65/data/#> .
@prefix rdfs:          <http://www.w3.org/2000/01/rdf-schema#> .
@prefix schema:        <http://schema.org/> .
@prefix xsd:           <http://www.w3.org/2001/XMLSchema#> .

@prefix dpp-odp:       <http://w3id.org/dppo/ontology/dpp-odp/> .
@prefix ceon-product:  <http://w3id.org/CEON/ontology/product/> .
@prefix ceon-process:  <http://w3id.org/CEON/ontology/process/> .
@prefix resourceODP:   <http://w3id.org/CEON/ontology/resourceODP/> .
@prefix processODP:    <http://w3id.org/CEON/ontology/processODP/> .

#################################################################
# DPP product and disassembly instruction
#################################################################

notor65:Notor65_BetaOpti a dpp:Product ;
    dpp:hasComponent notor65:battery,
        notor65:cobLED,
        notor65:driver,
        notor65:linearLED,
        notor65:psu,
        notor65:roundLED,
        notor65:sensorUnit,
        notor65:squareLED ;
    dpp:hasFastener notor65:clip,
        notor65:flap,
        notor65:screw .

notor65:battery     a dpp:Battery .
notor65:cobLED      a dpp:COBLEDCard .
notor65:driver      a dpp:Driver .
notor65:linearLED   a dpp:LinearLEDCard .
notor65:psu         a dpp:PSU .
notor65:roundLED    a dpp:RoundLEDCard .
notor65:sensorUnit  a dpp:SensorUnit .
notor65:squareLED   a dpp:SquareLEDCard .

notor65:clip  a dpp:Clip .
notor65:flap  a dpp:Flap .
notor65:screw a dpp:Screw .

notor65:Notor65_BetaOpti_DisassemblyInstruction
    a dpp:DisassemblyInstruction ;
    dpp:hasFirstStep dpp:PowerDisconnection ;
    dpp:hasInstructionDetail dpp:PowerDisconnection,
                             dpp:DismantleLuminaire,
                             dpp:DisassembleLuminaire,
                             dpp:MaterialSeparation ;
    rdfs:seeAlso <https://www.fagerhult.com/Products/notor/notor-65-beta-opti/> .

dpp:PowerDisconnection
    a dpp:SequentialInstructionDetail ;
    schema:description "Switch off electric supply to luminaire" ;
    dpp:hasNext dpp:DismantleLuminaire ;
    dpp:stepOrder "1.0"^^xsd:decimal .

dpp:DismantleLuminaire
    a dpp:SequentialInstructionDetail ;
    schema:description "Dismantle the luminaire starting with external covers and accessible components. See the mounting instruction for your product for guidance" ;
    rdfs:seeAlso <http://www.fagerhult.com/mounting-instructions/Notor65> ;
    dpp:hasNext dpp:DisassembleLuminaire ;
    dpp:stepOrder "2.0"^^xsd:decimal .

dpp:DisassembleLuminaire
    a dpp:SequentialInstructionDetail ;
    schema:description "Disassemble the luminaire for component separation" ;
    dpp:hasFirstStep dpp:ToolPreparation ;
    dpp:hasNext dpp:MaterialSeparation ;
    dpp:hasSubStep dpp:ComponentRemoval,
                   dpp:IdentifyElectricalComponents,
                   dpp:IdentifyLightSources,
                   dpp:ToolPreparation ;
    dpp:stepOrder "3.0"^^xsd:decimal .

dpp:ToolPreparation
    a dpp:SequentialInstructionDetail ;
    schema:description "Use suitable tools to loosen screws and other fastenings" ;
    dpp:hasNext dpp:ComponentRemoval ;
    dpp:stepOrder "3.1"^^xsd:decimal .

dpp:ComponentRemoval
    a dpp:SequentialInstructionDetail ;
    schema:description "Carefully remove each component from the housing including reflectors, lenses and other components to locate the LED or light source" ;
    dpp:hasNext dpp:IdentifyLightSources ;
    dpp:removes dpp:GlareProtection,
                dpp:Lens,
                dpp:Reflector ;
    dpp:stepOrder "3.2"^^xsd:decimal .

dpp:IdentifyLightSources
    a dpp:SequentialInstructionDetail ;
    schema:description "Identify and sort different types of light sources" ;
    dpp:hasNext dpp:IdentifyElectricalComponents ;
    dpp:stepOrder "3.3"^^xsd:decimal .

dpp:IdentifyElectricalComponents
    a dpp:SequentialInstructionDetail ;
    schema:description "Locate and label all electrical components for proper disposal or recycling" ;
    dpp:hasNext dpp:MaterialSeparation ;
    dpp:stepOrder "3.4"^^xsd:decimal .

dpp:MaterialSeparation
    a dpp:LastStep,
      dpp:SequentialInstructionDetail ;
    schema:description "Separate materials according to type for recycling or disposal" ;
    dpp:stepOrder "4.0"^^xsd:decimal .

#################################################################
# DPPO and CEON schema alignment
#################################################################

dpp-odp:Product a rdfs:Class .
dpp-odp:DPP     a rdfs:Class .

dpp-odp:describes a rdf:Property ;
    rdfs:domain dpp-odp:DPP ;
    rdfs:range  dpp-odp:Product .

resourceODP:Resource       a rdfs:Class .
resourceODP:BatchOfObjects a rdfs:Class ;
    rdfs:subClassOf resourceODP:Resource .

ceon-product:Product a rdfs:Class ;
    rdfs:subClassOf resourceODP:Resource .

ceon-product:Item a rdfs:Class ;
    rdfs:subClassOf resourceODP:Resource .

ceon-product:batchOfProduct a rdf:Property ;
    rdfs:domain resourceODP:BatchOfObjects ;
    rdfs:range  ceon-product:Product .

ceon-product:modelledBy a rdf:Property ;
    rdfs:domain ceon-product:Item ;
    rdfs:range  ceon-product:Product .

processODP:Process a rdfs:Class .

processODP:hasInput a rdf:Property ;
    rdfs:domain processODP:Process ;
    rdfs:range  resourceODP:Resource .

ceon-process:DisassemblingProcess a rdfs:Class ;
    rdfs:subClassOf processODP:Process .

# Alignment axioms

dpp:Product     rdfs:subClassOf dpp-odp:Product .
dpp-odp:Product rdfs:subClassOf ceon-product:Product .

dpp:guidesProcess a rdf:Property ;
    rdfs:domain dpp-odp:DPP ;
    rdfs:range  ceon-process:DisassemblingProcess .

#################################################################
# Application use case instances for DPPO and CEON
#################################################################

notor65:Notor65_BetaOpti
    a dpp-odp:Product ,
      ceon-product:Product .

# Digital product passport instance for this product

notor65:Notor65_BetaOpti_DPP
    a dpp-odp:DPP ;
    dpp-odp:describes notor65:Notor65_BetaOpti ;
    dpp:guidesProcess notor65:Notor65_BetaOpti_DisassemblingProcess .

# CEON batch, item and disassembling process

notor65:Batch_N65BO_2025M05
    a resourceODP:BatchOfObjects ;
    ceon-product:batchOfProduct notor65:Notor65_BetaOpti .

notor65:Item_7320046630874
    a ceon-product:Item ;
    ceon-product:modelledBy notor65:Notor65_BetaOpti .

notor65:Notor65_BetaOpti_DisassemblingProcess
    a ceon-process:DisassemblingProcess ;
    processODP:hasInput notor65:Notor65_BetaOpti .

#################################################################
# Product specific front side components
#################################################################

notor65:glareProtection_N65BO
    a dpp:GlareProtection ;
    schema:name "Beta Opti glare protection"@en .

notor65:lens_N65BO
    a dpp:Lens ;
    schema:name "Optical lens"@en .

notor65:reflector_N65BO
    a dpp:Reflector ;
    schema:name "Optical reflector"@en .

# components

notor65:Notor65_BetaOpti
    a dpp:Product ;
    dpp:hasComponent notor65:battery,
                     notor65:cobLED,
                     notor65:driver,
                     notor65:linearLED,
                     notor65:psu,
                     notor65:roundLED,
                     notor65:sensorUnit,
                     notor65:squareLED,
                     notor65:glareProtection_N65BO,
                     notor65:lens_N65BO,
                     notor65:reflector_N65BO ;
    dpp:hasFastener notor65:clip,
                    notor65:flap,
                    notor65:screw .

#################################################################
# Disassembly substep that removes the first components
#################################################################

dpp:ComponentRemoval
    a dpp:SequentialInstructionDetail ;
    schema:description "Remove glare protection, reflectors, lenses and other components to locate the LED or light source"@en ;
    dpp:hasNext dpp:IdentifyLightSources ;
    dpp:removes notor65:glareProtection_N65BO,
                notor65:lens_N65BO,
                notor65:reflector_N65BO ;
    dpp:stepOrder "3.2"^^xsd:decimal .

#################################################################
# New specialisations of CEON Resource
#################################################################

resourceODP:Tool a owl:Class ;
    rdfs:subClassOf resourceODP:Resource ;
    rdfs:label "Tool"@en .

resourceODP:ProtectiveEquipment a owl:Class ;
    rdfs:subClassOf resourceODP:Resource ;
    rdfs:label "Protective equipment"@en .

#################################################################
# Product specific tools and protective equipment
#################################################################

notor65:SuitableTools_N65BO
    a resourceODP:Tool ;
    schema:description "Suitable tools to loosen screws and other fastenings"@en .

notor65:ProtectiveGloves_N65BO
    a resourceODP:ProtectiveEquipment ;
    schema:name "Protective gloves for handling the luminaire"@en .

#################################################################
# Resources required during disassembly
#################################################################

notor65:Notor65_BetaOpti_DisassemblingProcess
    a ceon-process:DisassemblingProcess ;
    processODP:hasInput notor65:Notor65_BetaOpti ,
                        notor65:SuitableTools_N65BO ,
                        notor65:ProtectiveGloves_N65BO .

notor65:SuitableTools_N65BO
    a resourceODP:Resource ;
    schema:description "Suitable tools to loosen screws and other fastenings"@en .

notor65:ProtectiveGloves_N65BO
    a resourceODP:Resource ;
    schema:name "Protective gloves for handling the luminaire"@en .

#################################################################
# Extend the disassembling process inputs
#################################################################

notor65:Notor65_BetaOpti_DisassemblingProcess
    processODP:hasInput notor65:Notor65_BetaOpti ,
                        notor65:SuitableTools_N65BO ,
                        notor65:ProtectiveGloves_N65BO .

#################################################################
# Product, DPP and disassembling process
#################################################################

notor65:Notor65_BetaOpti
    a dpp:Product ,
      dpp-odp:Product ,
      ceon-product:Product .

notor65:Notor65_BetaOpti_DPP
    a dpp-odp:DPP ;
    dpp-odp:describes notor65:Notor65_BetaOpti ;
    dpp:guidesProcess notor65:Notor65_BetaOpti_DisassemblingProcess .

notor65:Notor65_BetaOpti_DisassemblingProcess
    a ceon-process:DisassemblingProcess ;
    processODP:hasInput notor65:Notor65_BetaOpti ,
                        notor65:SuitableTools_N65BO ,
                        notor65:ProtectiveGloves_N65BO .

#################################################################
# Disassembly steps (excerpt, unchanged semantics)
#################################################################

dpp:DisassembleLuminaire
    a dpp:SequentialInstructionDetail ;
    schema:description "Disassemble the luminaire for component separation"@en ;
    dpp:hasFirstStep dpp:ToolPreparation ;
    dpp:hasNext dpp:MaterialSeparation ;
    dpp:hasSubStep dpp:ComponentRemoval ,
                   dpp:IdentifyElectricalComponents ,
                   dpp:IdentifyLightSources ,
                   dpp:ToolPreparation ;
    dpp:stepOrder "3.0"^^xsd:decimal .

dpp:ToolPreparation
    a dpp:SequentialInstructionDetail ;
    schema:description "Use suitable tools to loosen screws and other fastenings"@en ;
    dpp:hasNext dpp:ComponentRemoval ;
    dpp:stepOrder "3.1"^^xsd:decimal .

#################################################################
# Resources required during disassembly
#################################################################

notor65:SuitableTools_N65BO
    a resourceODP:Resource ;
    schema:description "Suitable tools to loosen screws and other fastenings"@en .

notor65:ProtectiveGloves_N65BO
    a resourceODP:Resource ;
    schema:name "Protective gloves for handling the luminaire"@en .

notor65:SuitableTools_N65BO
    a resourceODP:Resource ;
    schema:description "Suitable tools to loosen screws and other fastenings"@en .

notor65:ProtectiveGloves_N65BO
    a resourceODP:Resource ;
    schema:name "Protective gloves for handling the luminaire"@en .

notor65:Screwdriver_N65BO
    a resourceODP:Resource ;
    schema:name "Screwdriver"@en .

#################################################################
# Make all three resources inputs to the disassembling process
#################################################################

notor65:Notor65_BetaOpti_DisassemblingProcess
    processODP:hasInput notor65:Notor65_BetaOpti ,
                        notor65:SuitableTools_N65BO ,
                        notor65:ProtectiveGloves_N65BO ,
                        notor65:Screwdriver_N65BO .

#################################################################
# Context for the disassembly instruction of Notor65 Beta Opti
#################################################################

notor65:Notor65_BetaOpti_DisassemblyContext
    a dpp:Context ;
    schema:description "Disassembly of the Notor65 Beta Opti luminaire during end of life handling"@en ;
    schema:location "Recycling or renovation facility"@en ;
    schema:category "End of life disassembly context for suspended indoor office luminaires"@en .

#################################################################
# Link the disassembly instruction to its context
#################################################################

notor65:Notor65_BetaOpti_DisassemblyInstruction
    a dpp:DisassemblyInstruction ;

    dpp:hasContext notor65:Notor65_BetaOpti_DisassemblyContext .
