@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix ceon:  <https://w3id.org/ceon/ontology/> .
@prefix dppo:  <https://w3id.org/dppo/ontology/> .
@prefix glass: <https://w3id.org/glass/ontology/> .
@prefix ifc:   <https://standards.buildingsmart.org/IFC/DEV/IFC4/ADD2/OWL#> .
@prefix qudt:  <http://qudt.org/schema/qudt/> .
@prefix quantitykind:  <https://qudt.org/vocab/quantitykind/> .
@prefix quantityunit: <http://qudt.org/vocab/unit/> .
@prefix ex:    <http://example.org/> .

# ====================
# Classes (14 concepts)
# ====================

ceon:MatterComposition a owl:Class .
ceon:Material a owl:Class .

ifc:BuiltElement a owl:Class .

glass:Window a owl:Class ;
    rdfs:subClassOf ifc:BuiltElement .

glass:WindowGlass a owl:Class ;
    rdfs:subClassOf ifc:BuiltElement .

dppo:DPP a owl:Class .

dppo:Product a owl:Class .

dppo:Substance a owl:Class ;
    rdfs:subClassOf dppo:Product .

dppo:DPPInformation a owl:Class .

dppo:CompositionInformation a owl:Class ;
    rdfs:subClassOf dppo:DPPInformation .

dppo:ProductCharacteristic a owl:Class ;
    rdfs:subClassOf dppo:DPPInformation .

qudt:QuantityKind a owl:Class .

qudt:Unit a owl:Class .

# ====================
# Instances & Relationships
# ====================

ex:FireClass  a ceon:Material .

ex:Asbestos  a ceon:Material .

# _a: a product that is a window
ex:_a a ceon:Item , glass:Window ;
    glass:numberOfPanes "2"^^xsd:integer .

# itemDPP_1: the Digital Product Passport
ex:itemDPP_1 a dppo:DPP ;
    dppo:describes ex:_a ;
    dppo:containsInformation ex:_c , ex:_f , ex:_e, ex:_g, ex:_i, ex:_h .

# _c: composition information about the window
ex:_c a dppo:CompositionInformation ;
    dppo:hasWhole ex:_a ;
    dppo:hasPart ex:_b , ex:_d .

# _b and _d: window glass parts
ex:_b a glass:WindowGlass .

ex:_d a glass:WindowGlass .


# _e: product characteristic about _b (thickness = 2 mm)
ex:_e a dppo:ProductCharacteristic ;
    dppo:isAbout ex:_b ;
    dppo:value "2"^^xsd:integer ;
    qudt:hasQuantityKind quantitykind:Thickness ;
    qudt:unit quantityunit:MilliM .

# _f: product characteristic about _d (thickness = 3 mm)
ex:_f a dppo:ProductCharacteristic ;
    dppo:isAbout ex:_d ;
    dppo:value "3"^^xsd:integer ;
    qudt:hasQuantityKind quantitykind:Thickness ;
    qudt:unit quantityunit:MilliM .

# _g: product characteristic about _d (area = 3 squaremeter)
ex:_g a dppo:ProductCharacteristic ;
    dppo:isAbout ex:_a ;
    dppo:value "1.54"^^xsd:integer ;
    qudt:hasQuantityKind quantitykind:Area ;
    qudt:unit quantityunit:M2 .


# _h: product characteristic about _d 
ex:_h a dppo:ProductCharacteristic ;
    dppo:isAbout ex:_d ;
    dppo:value "false"^^xsd:boolean ;
    dppo:characteristic ex:FireClass .

# _i: product characteristic about _d 
ex:_i a dppo:ProductCharacteristic ;
    dppo:isAbout ex:_d ;
    dppo:value "false"^^xsd:boolean ;
    dppo:characteristic ex:Asbestos .

# Quantity kind and unit instances
quantitykind:Thickness a qudt:QuantityKind .
quantitykind:Area a qudt:QuantityKind .

quantityunit:MilliM a qudt:Unit .
quantityunit:M2 a qudt:Unit .
