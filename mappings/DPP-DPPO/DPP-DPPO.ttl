@prefix dc: <http://purl.org/dc/elements/1.1/> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix semapv: <https://w3id.org/semapv/vocab/> .
@prefix sssom: <https://w3id.org/sssom/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

owl:annotatedProperty a rdf:Property .

owl:annotatedSource a rdf:Property .

owl:annotatedTarget a rdf:Property .

<https://w3id.org/dpp/alignment/dpp-dppo/> a owl:Ontology ;
    dcterms:contributor "Eva Blomqvist",
        "Huanyu Li",
        "Rahel Kebede" ;
    dcterms:created "2026-01-23"^^xsd:date ;
    dcterms:creator "Rahel Kebede" ;
    dcterms:license "https://creativecommons.org/licenses/by/4.0/" ;
    dcterms:source "https://github.com/RichZele/DPP-DPPO-CEON-Ontology-Alignment/blob/main/documentations/DPP-DPPO.xlsx" ;
    dcterms:title "The alignment ontology between DPP ontology and DPPO" ;
    rdfs:comment "This ontology represents the alignment between the Digital Product Passport (DPP) ontology and Digital Product Passport Ontology (DPPO)." ;
    owl:versionInfo "0.1" .

<https://w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0001> a sssom:Mapping ;
    dc:identifier "DPP_DPPO_0001" ;
    dcterms:source "https://w3id.org/dpp/alignment/dpp-dppo/" ;
    rdfs:comment "DPP is stricter: product≠material; DPPO keeps them possibly overlapping. Subclass mapping preserves DPPO’s sector-agnostic stance without breaking DPP's disjointness." ;
    owl:annotatedProperty rdfs:subClassOf ;
    owl:annotatedSource <http://www.w3id.org/dpp#Product> ;
    owl:annotatedTarget <http://w3id.org/dppo/ontology/dpp-odp/Product> ;
    sssom:mapping_justificatio semapv:ManualMappingCuration ;
    sssom:object_label "Product" ;
    sssom:object_type owl:Class ;
    sssom:subject_label "Product" ;
    sssom:subject_type owl:Class .

<https://w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0002> a sssom:Mapping ;
    dc:identifier "DPP_DPPO_0002" ;
    dcterms:source "https://w3id.org/dpp/alignment/dpp-dppo/" ;
    rdfs:comment "Both represent part-whole relationships. Structural correspondence: both as subclasses of Product with part-of links. Modular alignment allows complex product breakdowns in DPP (e.g., building elements into sub-components) to map into DPPO’s composition pattern." ;
    owl:annotatedProperty owl:equivalentClass ;
    owl:annotatedSource <http://www.w3id.org/dpp#Component> ;
    owl:annotatedTarget <http://w3id.org/dppo/ontology/dpp-core/Component> ;
    sssom:mapping_justificatio semapv:ManualMappingCuration ;
    sssom:object_label "Component" ;
    sssom:object_type owl:Class ;
    sssom:subject_label "Component" ;
    sssom:subject_type owl:Class .

<https://w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0003> a sssom:Mapping ;
    dc:identifier "DPP_DPPO_0003" ;
    dcterms:source "https://w3id.org/dpp/alignment/dpp-dppo/" ;
    rdfs:comment "Semantically equivalent: both capture the matter constituting products/parts. Subclass mapping (dppo:Material ⊑ dppo:Product) reflects DPPO’s flexibility; DPP’s modular placement preserves structure. Alignment preserves CE relevance (resource loops, recyclability)." ;
    owl:annotatedProperty rdfs:subClassOf ;
    owl:annotatedSource <http://www.w3id.org/dpp#Material> ;
    owl:annotatedTarget <http://w3id.org/dppo/ontology/dpp-core/Material> ;
    sssom:mapping_justificatio semapv:ManualMappingCuration ;
    sssom:object_label "Material" ;
    sssom:object_type owl:Class ;
    sssom:subject_label "Material" ;
    sssom:subject_type owl:Class .

<https://w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0004> a sssom:Mapping ;
    dc:identifier "DPP_DPPO_0004" ;
    dcterms:source "https://w3id.org/dpp/alignment/dpp-dppo/" ;
    rdfs:comment "Both model partonomy as first-class nodes; quantitative details remain attached to the reified link." ;
    owl:annotatedProperty rdfs:subClassOf ;
    owl:annotatedSource <http://www.w3id.org/dpp#MaterialComposition> ;
    owl:annotatedTarget <http://w3id.org/dppo/ontology/dpp-info/CompositionInformation> ;
    sssom:mapping_justificatio semapv:ManualMappingCuration ;
    sssom:object_label "CompositionInformation" ;
    sssom:object_type owl:Class ;
    sssom:subject_label "MaterialComposition" ;
    sssom:subject_type owl:Class .

<https://w3id.org/dpp/alignment/dpp-dppo/DPP_DPPO_0005> a sssom:Mapping ;
    dc:identifier "DPP_DPPO_0005" ;
    dcterms:source "https://w3id.org/dpp/alignment/dpp-dppo/" ;
    rdfs:comment "For product-level roles, keep DPP’s AgentRole on dpp:Product; additionally mint DPPO responsibleActor on each DPPInformation item to meet DPPO’s auditability." ;
    owl:annotatedProperty owl:equivalentClass ;
    owl:annotatedSource <http://www.w3id.org/dpp#Agent> ;
    owl:annotatedTarget <http://w3id.org/dppo/ontology/dpp-prov/Actor> ;
    sssom:mapping_justificatio semapv:ManualMappingCuration ;
    sssom:object_label "Actor" ;
    sssom:object_type owl:Class ;
    sssom:subject_label "Agent" ;
    sssom:subject_type owl:Class .

<http://www.w3id.org/dpp#Agent> a owl:Class ;
    owl:equivalentClass <http://w3id.org/dppo/ontology/dpp-prov/Actor> .

<http://www.w3id.org/dpp#Component> a owl:Class ;
    owl:equivalentClass <http://w3id.org/dppo/ontology/dpp-core/Component> .

<http://www.w3id.org/dpp#Material> a owl:Class ;
    rdfs:subClassOf <http://w3id.org/dppo/ontology/dpp-core/Material> .

<http://www.w3id.org/dpp#MaterialComposition> a owl:Class ;
    rdfs:subClassOf <http://w3id.org/dppo/ontology/dpp-info/CompositionInformation> .

<http://www.w3id.org/dpp#Product> a owl:Class ;
    rdfs:subClassOf <http://w3id.org/dppo/ontology/dpp-odp/Product> .

<http://w3id.org/dppo/ontology/dpp-core/Component> a owl:Class .

<http://w3id.org/dppo/ontology/dpp-core/Material> a owl:Class .

<http://w3id.org/dppo/ontology/dpp-info/CompositionInformation> a owl:Class .

<http://w3id.org/dppo/ontology/dpp-odp/Product> a owl:Class .

<http://w3id.org/dppo/ontology/dpp-prov/Actor> a owl:Class .

